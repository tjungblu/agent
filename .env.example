# Anthropic via Google Cloud Vertex AI (required)
ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id
ANTHROPIC_VERTEX_REGION=us-east5

# Atlassian MCP Server Configuration (required for Jira integration)
# Uses OAuth 2.1 - no API tokens needed!
MCP_SERVER_URL=https://mcp.atlassian.com/v1/mcp/authv2
ATLASSIAN_SITE=yourcompany.atlassian.net

# Brief schedule (optional, defaults to hourly)
# Options: hourly, daily, custom
BRIEF_SCHEDULE=hourly

# State file location (optional, defaults to ./state.json)
STATE_FILE=state.json

# Brief output format (optional, defaults to terminal)
# Options: terminal, markdown, json, slack
OUTPUT_FORMAT=markdown

# Log level (optional, defaults to INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
